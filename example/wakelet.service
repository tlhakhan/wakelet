[Unit]
Description=Wakelet — Wake-on-LAN web app
After=network.target

[Service]
Type=simple
User=wakelet
Group=wakelet
WorkingDirectory=/home/wakelet/wakelet
ExecStart=/home/wakelet/wakelet/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
